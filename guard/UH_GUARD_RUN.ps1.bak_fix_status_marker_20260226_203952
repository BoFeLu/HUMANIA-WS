function Integrity-Check-ArtifactConsistency {
  param(
    [string]$RunId,
    [string]$Trigger,
    [string]$ContextPath,
    [string]$StatusPath,
    [string]$ConstPath,
    [string]$InventoryPath,
    [string]$MiniPath

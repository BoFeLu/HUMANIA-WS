    if (!(Test-Path $f)) {
      throw "INTEGRITY_FAIL: Missing file: $f"
    }
    if ((Get-Item $f).Length -eq 0) {
      throw "INTEGRITY_FAIL: Empty file detected: $f"
    }
  }
}


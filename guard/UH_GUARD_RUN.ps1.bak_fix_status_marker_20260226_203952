    "C:\HUMANIA\docs\laws\vital\UH_GUARD_SPEC_v1.md",
    "C:\HUMANIA\docs\laws\vital\UH_STATUS_REPORT_GENERATION_PROCEDURE_v1.md",
    "C:\HUMANIA\verifiers\silent_run.vbs"
